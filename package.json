{
  "name": "preflop-trainer",
  "version": "0.1.6",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test": "jest",
    "test:unit": "jest --runInBand",
    "test:components": "jest --config jest.components.config.js --runInBand",
    "test:ci": "jest --runInBand --coverage && npm run test:components",
    "test:engine": "jest src/engine",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "export:web": "expo export --platform web",
    "verify:release": "node scripts/verify_public_release.mjs",
    "ranges:import:pokerstudy": "node scripts/import_pokerstudy.mjs",
    "check": "npm run typecheck && npm run lint && npm run test:ci && npm run verify:release"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "~57.0.7",
    "expo-asset": "~57.0.6",
    "expo-constants": "~57.0.6",
    "expo-font": "~57.0.1",
    "expo-linking": "~57.0.3",
    "expo-router": "~57.0.7",
    "expo-splash-screen": "~57.0.4",
    "expo-status-bar": "~57.0.1",
    "expo-system-ui": "~57.0.1",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.86.0",
    "react-native-reanimated": "4.5.0",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "4.25.2",
    "react-native-web": "^0.21.0",
    "react-native-worklets": "0.10.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@babel/core": "^7.25.2",
    "@react-native/jest-preset": "^0.86.0",
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.2.10",
    "eslint": "^9.39.5",
    "eslint-config-expo": "^57.0.0",
    "jest": "^29.7.0",
    "jest-expo": "~57.0.2",
    "prettier": "^3.9.5",
    "react-test-renderer": "^19.2.3",
    "ts-jest": "^29.2.5",
    "typescript": "~6.0.3"
  },
  "private": true
}
